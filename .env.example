# Environment variables for Vetrivel Groups site
# Copy this file to .env.local and fill in real values before connecting
# the contact form to a live email/CRM service.

# --- Contact form email delivery (choose one provider) ---
# Resend (https://resend.com)
# RESEND_API_KEY=
# CONTACT_FORM_TO_EMAIL=sukumar@vetrivelgroups.in

# SendGrid (https://sendgrid.com)
# SENDGRID_API_KEY=

# --- Site URL (used in metadata, sitemap, JSON-LD) ---
# NEXT_PUBLIC_SITE_URL=https://www.vetrivelgroups.in
